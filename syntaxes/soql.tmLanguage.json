{
  "scopeName": "source.soql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.soql",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.soql",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.soql",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.soql",
          "match": "(?i)\\b(SELECT|FROM|WHERE|AND|OR|NOT|IN|LIKE|ORDER\\s+BY|GROUP\\s+BY|HAVING|LIMIT|OFFSET|ASC|DESC|NULLS\\s+FIRST|NULLS\\s+LAST|WITH|USING\\s+SCOPE|FOR\\s+VIEW|FOR\\s+REFERENCE|FOR\\s+UPDATE|INCLUDES|EXCLUDES|TYPEOF|WHEN|THEN|ELSE|END|ROLLUP|CUBE)\\b"
        },
        {
          "name": "constant.language.null.soql",
          "match": "(?i)\\b(NULL|TRUE|FALSE)\\b"
        },
        {
          "name": "keyword.other.date-literal.soql",
          "match": "(?i)\\b(YESTERDAY|TODAY|TOMORROW|LAST_WEEK|THIS_WEEK|NEXT_WEEK|LAST_MONTH|THIS_MONTH|NEXT_MONTH|LAST_90_DAYS|NEXT_90_DAYS|LAST_N_DAYS|NEXT_N_DAYS|THIS_QUARTER|LAST_QUARTER|NEXT_QUARTER|THIS_YEAR|LAST_YEAR|NEXT_YEAR|THIS_FISCAL_QUARTER|LAST_FISCAL_QUARTER|NEXT_FISCAL_QUARTER|THIS_FISCAL_YEAR|LAST_FISCAL_YEAR|NEXT_FISCAL_YEAR|LAST_N_QUARTERS|NEXT_N_QUARTERS|LAST_N_YEARS|NEXT_N_YEARS|LAST_N_FISCAL_QUARTERS|NEXT_N_FISCAL_QUARTERS|LAST_N_FISCAL_YEARS|NEXT_N_FISCAL_YEARS|LAST_N_MONTHS|NEXT_N_MONTHS|LAST_N_WEEKS|NEXT_N_WEEKS)\\b"
          }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.aggregate.soql",
          "match": "(?i)\\b(COUNT|AVG|SUM|MIN|MAX|COUNT_DISTINCT|GROUPING|FORMAT|convertCurrency|toLabel|convertTimezone|CALENDAR_MONTH|CALENDAR_QUARTER|CALENDAR_YEAR|DAY_IN_MONTH|DAY_IN_WEEK|DAY_IN_YEAR|DAY_ONLY|FISCAL_MONTH|FISCAL_QUARTER|FISCAL_YEAR|HOUR_IN_DAY|WEEK_IN_MONTH|WEEK_IN_YEAR|FIELDS)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.soql",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.soql",
          "match": "(!=|<>|<=|>=|=|<|>)"
        }
      ]
    }
  }
}
